<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.PostMapper">

    <select id="findAll" resultType="com.blog.entity.Post">
        select * from post
    </select>

    <select id="getByPage" resultType="com.blog.entity.Post">
        select * from post order by create_time desc limit #{offset}, #{size}
    </select>

    <select id="getById" resultType="com.blog.entity.Post">
        select * from post where id=#{id}
    </select>

    <insert id="insert">
        insert into post(title,context,user_id,create_time)
        values (#{title},#{context},#{userId},#{createTime})

    </insert>

    <update id="update">
        update post set title=#{title}, context=#{context} where id=#{id}
    </update>

    <delete id="delete">
        delete from post where id=#{id}
    </delete>

    <select id="searchByTitle" resultType="com.blog.entity.Post">
        select * from post where title like concat('%',#{keyword},'%')
    </select>
    
    <select id="selectHotPosts" resultType="com.blog.entity.Post">
        select * from post ORDER BY view_count desc limit 5
    </select>

</mapper>
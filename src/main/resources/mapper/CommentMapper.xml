<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.CommentMapper">

    <insert id="publishComment">
        insert into comment (post_id,user_id,content,create_time)
        values (#{postId},#{userId},#{content},#{createTime})
    </insert>

    <select id="selectByPostId" resultType="com.blog.entity.Comment">
        select * from comment where post_id = #{postId} order by create_time desc
    </select>

</mapper>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.PostLikeMapper">
    <insert id="insert">
        insert into post_like (user_id,post_id) values (#{userId},#{postId})
    </insert>

    <delete id="delete">
        delete from post_like where user_id=#{userId} and post_id=#{postId}
    </delete>

    <select id="isLike" resultType="com.blog.entity.PostLike">
        select * from post_liek where user_id=#{userId} and post_id=#{postId}
    </select>
</mapper>
version: '3.9'

networks:
  blog-network:
    driver: bridge

services:
  mysql:
    image: mysql:8.0
    container_name: blog-mysql
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: MyNewPass123!
    ports:
      - "3306:3306"
    volumes:
      - /home/blog-project/mysql/data:/var/lib/mysql
      - /home/blog-project/mysql/init:/docker-entrypoint-initdb.d
      - /home/blog-project/mysql/conf:/etc/mysql/conf.d
    command: --default-authentication-plugin=mysql_native_password
    networks:
      - blog-network

  redis:
    image: redis:7
    container_name: blog-redis
    restart: always
    ports:
      - "6379:6379"
    volumes:
      - /home/blog-project/redis/data:/data
      - /home/blog-project/redis/redis.conf:/usr/local/etc/redis/redis.conf
    command: redis-server /usr/local/etc/redis/redis.conf
    networks:
      - blog-network

  blog:
    build: ./blog
    container_name: blog-app
    restart: always
    ports:
      - "8080:8080"
    depends_on:
      - mysql
      - redis
    environment:
      SPRING_PROFILES_ACTIVE: prod
    networks:
      - blog-network
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.blog.mapper.CommentMapper">
    <resultMap id="commentMap" type="com.blog.entity.Comment">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="post_id" property="postId"/>
        <result column="create_time" property="createTime"/>
        <result column="parent_id" property="parentId"/>
    </resultMap>

    <insert id="publishComment">
        insert into comment (post_id,user_id,content,create_time,parent_id)
        values (#{postId},#{userId},#{content},#{createTime},#{parentId})
    </insert>

    <select id="selectByPostId" resultType="com.blog.entity.Comment" resultMap="commentMap">
        select * from comment where post_id = #{postId} order by create_time desc
    </select>

    <select id="selectByUserId" resultMap="commentMap">
        select * from comment where user_id=#{userId} and create_time>=DATE_SUB(NOW(),interval 7 day) order by create_time desc
    </select>

</mapper>